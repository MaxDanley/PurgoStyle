# PurgoLabs SummerSteeze – copy to .env.local and fill in

# Database (Supabase – use a new project for PurgoLabs SummerSteeze)
DATABASE_URL="postgresql://..."

# NextAuth
NEXTAUTH_SECRET="generate-a-secret"
NEXTAUTH_URL="http://localhost:3000"

# Resend (new API key for PurgoLabs SummerSteeze)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@summersteez.com"
SUPPORT_EMAIL="help@summersteez.com"

# Website A → PurgoLabs SummerSteeze server-to-server auth (verify session, create checkout)
STRIPE_CREATE_SESSION_SECRET="shared-secret-for-website-a"
WEBSITE_B_INTERNAL_SECRET="same-as-above-if-you-prefer"

# PayPal — Website A / launch-checkout (Orders v2 Standard Checkout)
# https://developer.paypal.com/api/rest/
# REQUIRED for Live credentials: must be exactly "live" or OAuth hits sandbox and returns invalid_client (401).
# Use "sandbox" (or leave unset) only with Sandbox Client ID + Secret from Developer Dashboard.
PAYPAL_MODE="live"
PAYPAL_CLIENT_ID="your-paypal-rest-app-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-rest-app-secret"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="same-as-PAYPAL_CLIENT_ID-for-browser-sdk"
# Webhook ID from Developer Dashboard → your webhook → ID (for signature verification)
PAYPAL_WEBHOOK_ID=""
# Optional override (default https://www.purgolabs.com/payment-return)
WEBSITE_A_PAYMENT_RETURN_URL="https://www.purgolabs.com/payment-return"
# Website A: back button + PayPal cancel — where shoppers return if they abandon checkout (required in production)
WEBSITE_A_PAYMENT_CANCEL_URL="https://www.purgolabs.com/checkout"
# Optional fallback if WEBSITE_A_PAYMENT_CANCEL_URL is unset (default: origin of WEBSITE_A_PAYMENT_RETURN_URL)
WEBSITE_A_CHECKOUT_BACK_URL="https://www.purgolabs.com"

# Stripe (still used for normal PurgoLabs SummerSteeze cart checkout if configured)
STRIPE_SECRET_KEY=""

# Optional
NEXT_PUBLIC_BASE_URL="https://www.summersteez.com"
